<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ===================== ACTION ===================== -->
    <record id="gym_workout_action" model="ir.actions.act_window">
        <field name="name">Workouts</field>
        <field name="res_model">gym.workout</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- ===================== TREE VIEW ===================== -->
    <record id="gym_workout_tree" model="ir.ui.view">
        <field name="name">gym.workout.tree</field>
        <field name="model">gym.workout</field>
        <field name="arch" type="xml">
            <list>
                <field name="exercise_id"/>
                <field name="member_id"/>
                <field name="trainer_id"/>
                <field name="duration"/>
            </list>
        </field>
    </record>

    <!-- ===================== FORM VIEW ===================== -->
    <record id="gym_workout_form" model="ir.ui.view">
        <field name="name">gym.workout.form</field>
        <field name="model">gym.workout</field>
        <field name="arch" type="xml">
            <form string="Workout">
                <sheet>

                    <header>
                        <!-- Assign Workout Button -->
                        <button name="action_open_assign_wizard"
                                type="object"
                                string="Assign Workout"
                                class="btn-primary"/>
                    </header>

                    <group>
                       <field name="exercise_id"/>
                        <field name="member_id"/>
                        <field name="trainer_id"/>
                        <field name="duration"/>
                    </group>

                    <group string="Description">
                        <field name="description"/>
                    </group>

                    <!-- ✅ EQUIPMENTS -->
                    <group string="Equipments">
                        <field name="equipment_ids" widget="many2many_tags"/>
                    </group>

                </sheet>
            </form>
        </field>
    </record>

