<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="gym_membership_action" model="ir.actions.act_window">
        <field name="name">Membership Plans</field>
        <field name="res_model">gym.membership</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="gym_membership_tree" model="ir.ui.view">
        <field name="name">gym.membership.tree</field>
        <field name="model">gym.membership</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
<!--                <field name="duration"/>-->
                <field name="price"/>
            </list>
        </field>
    </record>

    <record id="gym_membership_form" model="ir.ui.view">
        <field name="name">gym.membership.form</field>
        <field name="model">gym.membership</field>
        <field name="arch" type="xml">
            <form>

<!--                <header>-->
<!--                    <button name="action_create_invoice"-->
<!--                            type="object"-->
<!--                            string="Create Invoice"-->
<!--                            class="oe_highlight"/>-->
<!--                </header>-->

                <sheet>
                    <group>
                        <field name="name"/>
<!--                        <field name="duration"/>-->
                        <field name="price"/>
                        <field name="description"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
</odoo>